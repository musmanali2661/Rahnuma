# =============================================================================
# Rahnuma Navigation System — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ---- Application ----
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ---- PostgreSQL / PostGIS ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rahnuma
POSTGRES_USER=rahnuma
POSTGRES_PASSWORD=rahnuma_secret

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT Authentication ----
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- OSRM Routing Engine ----
OSRM_HOST=http://localhost
OSRM_PORT=5000

# ---- Nominatim Geocoding ----
NOMINATIM_HOST=http://localhost
NOMINATIM_PORT=7070

# ---- Martin Tile Server ----
TILE_SERVER_HOST=http://localhost
TILE_SERVER_PORT=3000
TILE_SERVER_URL=http://localhost:3000

# ---- Web App ----
VITE_API_URL=http://localhost:4000
VITE_TILE_SERVER_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:4000

# ---- ML Service (Python) ----
ML_SERVICE_HOST=localhost
ML_SERVICE_PORT=8000

# ---- Offline Packages ----
OFFLINE_PACKAGES_DIR=./data/offline_packages
S3_BUCKET=
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:80
